PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/zahill_pms
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5174
DISPLAY_URL=http://localhost:5175
TV_URL=http://localhost:5176

# Room Display / TV Display auth
DISPLAY_TOKEN=your_display_token_here

# MQTT / IoT
MQTT_BROKER=mqtt://mqtt.d-zahill.kdai.cloud:1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=zahill-pms

# Market Insights (optional — features degrade gracefully without these)
GOOGLE_PLACES_API_KEY=
ANTHROPIC_API_KEY=

# Weather (Room Display / TV Display guest board)
OPENWEATHER_API_KEY=

# Guest Communication — platform-default SMTP, used when a property hasn't
# configured its own SMTP in Settings (property_settings.smtp_*)
PLATFORM_SMTP_HOST=smtp.gmail.com
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=your@gmail.com
PLATFORM_SMTP_PASSWORD=your-app-password
PLATFORM_SMTP_FROM=Your Platform <your@gmail.com>
