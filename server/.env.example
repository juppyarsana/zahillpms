PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/birdnest_pms
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Room Display / TV Display auth
DISPLAY_TOKEN=your_display_token_here

# MQTT / IoT
MQTT_BROKER=mqtt://mqtt.birdnestay.id:1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_CLIENT_ID=birdnest-pms
